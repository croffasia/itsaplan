# Shared .env for local dev and the self-hosting stack. Copy: cp .env.example .env
# Dev works with the values below as-is, except the secrets marked "generate one".
# Self-hosting needs real values for the secrets and public URLs; DATABASE_URL and
# S3_ENDPOINT are set by the compose file. Coolify uses docker-compose.coolify.yml.

# ── Postgres (docker-compose brings up the DB) ──
POSTGRES_USER=itsaplan
POSTGRES_PASSWORD=itsaplan
POSTGRES_DB=itsaplan
# Host port for the local dev DB. Change if 5432 is taken.
POSTGRES_PORT=5432

# ── Database connection (api + drizzle) ──
# Local; inside compose api reaches postgres by service name (postgres:5432).
DATABASE_URL=postgres://itsaplan:itsaplan@localhost:5432/itsaplan

# ── Public origins (each set once; every service derives from these) ──
# API_URL — api origin: auth handler, email links, and the web browser bundle.
# APP_URL — web origin: CORS/auth trusted origins, passkey, email links.
API_URL=http://localhost:3000
APP_URL=http://localhost:3001

# ── Legal document URLs (web build args) ──
# Shown on the logged-out screens; Google OAuth sign-in requires the privacy policy
# to be reachable. Point them at this instance's own documents. Leave empty to hide
# the legal notice. Inlined into the web bundle at build time (rebuild web to change).
# PRIVACY_URL=https://example.com/privacy
# TERMS_URL=https://example.com/terms

# ── better-auth ──
BETTER_AUTH_SECRET=change-me-please-generate-a-real-secret  # openssl rand -base64 32
# Passkey (WebAuthn) relying party. Defaults to the APP_URL hostname.
# In prod set to the public frontend hostname (no scheme, no port).
# PASSKEY_RP_ID=app.example.com
# PASSKEY_RP_NAME=Its a Plan
# Cookie domain override. Defaults to the parent domain of APP_URL;
# set only for multi-label TLDs or deep subdomains.
# COOKIE_DOMAIN=.example.com

# ── API (Elysia) ──
API_PORT=3000

# ── S3 object store: MinIO (issue attachments; metadata stays in the DB) ──
# Leave S3_* unset to disable uploads. The keys double as MinIO root credentials;
# the secret must be >= 8 chars. Upload limits are DB settings (god mode), not env.
S3_ENDPOINT=http://localhost:9000      # inside compose: http://minio:9000
S3_BUCKET=planner-attachments
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1                    # required by the SDK, ignored by MinIO

# ── Secret encryption (AI provider API keys at rest) ──
# 32-byte AES key derived from this via SHA-256. Changing it makes stored
# credentials undecryptable. openssl rand -base64 32
APP_ENCRYPTION_KEY=

# ── Internal token shared by api, worker and bot ──
# Same value for all three. openssl rand -base64 32
WORKER_INTERNAL_TOKEN=change-me-please-generate-a-real-secret

# ── Telegram bot (apps/bot) — the bot token is stored in the DB, not here ──
# BOT_CONFIG_POLL_INTERVAL_MS=30000  # how often to re-read bot settings from the API
# BOT_CONFIG_RETRY_INTERVAL_MS=5000  # retry delay after the API could not be reached
# BOT_API_TIMEOUT_MS=15000           # per-request timeout for calls to the API

# ── Background worker (apps/worker): webhooks, schedules, agent runs ──
# WEBHOOK_POLL_INTERVAL_MS=2000     # how often to poll for due deliveries
# WEBHOOK_BATCH_SIZE=20             # deliveries claimed/sent per tick
# WEBHOOK_TIMEOUT_MS=10000          # per-delivery HTTP timeout
# WEBHOOK_MAX_ATTEMPTS=8            # attempts before a delivery is dead-lettered
# WEBHOOK_DISABLE_THRESHOLD=20      # consecutive failures before a webhook is auto-disabled
# WEBHOOK_LEASE_SECONDS=120         # claim lease; a crashed delivery is retried after this
# WEBHOOK_CLEANUP_DAYS=30           # succeeded deliveries older than this are deleted
# WEBHOOK_CLEANUP_EVERY_TICKS=300   # run the cleanup once every N ticks
# AGENT_RUN_POLL_INTERVAL_MS=2000   # how often to poll for due agent runs
# AGENT_RUN_BATCH_SIZE=5            # agent runs claimed per tick
# AGENT_RUN_TIMEOUT_MS=240000       # internal API request timeout
# AGENT_RUN_MAX_ATTEMPTS=3          # attempts before a run is marked failed
# AGENT_RUN_LEASE_SECONDS=300       # claim lease for crash recovery
# NOTIFICATION_BATCH_SIZE=20        # notification deliveries claimed per tick
# NOTIFICATION_TIMEOUT_MS=20000     # internal send-API request timeout
# NOTIFICATION_MAX_ATTEMPTS=5       # attempts before a delivery is marked failed
# NOTIFICATION_LEASE_SECONDS=120    # claim lease for crash recovery

# From address for outbound email. Required for Resend (verified sender); for SMTP
# defaults to the SMTP username. NOTIFICATIONS_EMAIL_FROM is read as a fallback.
# EMAIL_FROM=Its a Plan <notifications@example.com>

# ── Web (Next.js) ──
# The browser bundle needs NEXT_PUBLIC_API_URL (= API_URL above) and the optional
# NEXT_PUBLIC_PRIVACY_URL / NEXT_PUBLIC_TERMS_URL (= PRIVACY_URL / TERMS_URL above),
# set in the separate apps/web/.env locally, or as Docker build args.
# WEB_PORT=3001   # host port for the web app (docker-compose.yml)
