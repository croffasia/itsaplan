# ─────────────────────────────────────────────────────────────
# Environment for the API test suite (bun test). Separate from .env so tests
# never touch the dev database. Copy to .env.test:  cp .env.test.example .env.test
#
# The tests are integration tests: they run the real Elysia app against a real
# Postgres and create real better-auth sessions. Point DATABASE_URL at a
# dedicated TEST database — the db reset helper TRUNCATEs every table between
# tests, so it must never point at the dev or prod database.
# ─────────────────────────────────────────────────────────────

# Dedicated test database on the local dev Postgres (docker-compose.dev.yml).
# The name must contain "test" — the reset helper refuses to run otherwise.
# Match the host/port/credentials of your dev DB; only the database name differs.
# Use the same POSTGRES_PORT as your dev DB (5433 if 5432 is taken — see root .env).
DATABASE_URL=postgres://vela:vela@localhost:5433/vela_test

# better-auth. Any fixed value works for a throwaway test DB.
BETTER_AUTH_SECRET=test-secret-not-for-production-use-only
API_URL=http://localhost:3000
APP_URL=http://localhost:3001

# NODE_ENV gates the db reset helper (belt-and-suspenders with the db-name check).
NODE_ENV=test

# S3-compatible object store (MinIO) for the attachments feature test. The local
# dev MinIO from docker-compose.dev.yml serves this; its minio-init creates the
# bucket. Reuse the same values as root .env — the test only writes uuid-keyed
# objects and deletes what it creates.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=planner-attachments
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Secret encryption key (AES-256-GCM) for stored provider API keys.
APP_ENCRYPTION_KEY=test-secret-not-for-production-use-only
