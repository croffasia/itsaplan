    "@elysiajs/cors": "^1.3.0",
    "@elysiajs/swagger": "^1.3.1",
    "@mastra/core": "^1.50.1",
    "@mastra/memory": "^1.22.2",
    "@mastra/pg": "^1.15.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@repo/agent-tools": "workspace:*",
    "@repo/auth": "workspace:*",
    "@repo/crypto": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/mailer": "workspace:*",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.44.2",
    "elysia": "^1.3.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@elysiajs/eden": "^1.3.0",
    "@repo/eslint-config": "workspace:*",
    "@types/bun": "latest",
    "eslint": "^9.39.0",
    "typescript": "^5.7.3"
  }
