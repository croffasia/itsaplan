{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "bun test --env-file=../../.env.test",
    "test:coverage": "bun test --env-file=../../.env.test --coverage; bun scripts/coverage-report.ts"
  },
  "dependencies": {
