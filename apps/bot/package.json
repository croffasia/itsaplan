{
  "name": "bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "if find src -name '*.test.ts' -print -quit | grep -q .; then bun test; fi"
  },
  "dependencies": {
    "grammy": "^1.45.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@types/bun": "latest",
    "eslint": "^9.39.0",
    "typescript": "^5.7.3"
  }
}
